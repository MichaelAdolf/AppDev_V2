    {
        "id": "light_demo_mapper",
        "type": "function",
        "z": "subflow_jarvis_light_demo",
        "name": "Licht Demo Response",
        "func": "const text = (msg.payload.rawText || \"\").toLowerCase();\n\nlet entityId = \"light.living_room\"\nlet action = \"turn_on\"\n\nif (text.includes(\"Schlafzimmer\")) {\n    entityId = 'light.bedroom';\n}\n\nif (text.includes(\"wohnzimmer\")) {\n    entityId = 'light.living_room';\n}\n\nif (text.includes(\"aus\")) {\n    action = 'turn_off';\n}\n\nif (text.includes(\"an\")) {\n    action = 'turn_on';\n}\n\nmsg.payload = {\n    success: true,\n    intent: \"light\",\n    entity: entityId,\n    state: action,\n    message: `${entityId} wurde über den Jarvis Router verarbeitet (${action}).`\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 270,
        "y": 100,
        "wires": [
            []
        ]
    },
