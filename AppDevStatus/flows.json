    {
        "id": "daily_generate_text",
        "type": "function",
        "z": "subflow_jarvis_daily_info",
        "name": "Erzeuge Tagesinfo",
        "func": "let now = new Date();\nlet weather = msg.payload.weather;\nlet calendar = msg.payload.calendar;\n\nfunction dayToText(day) {\n    const days = {\n        1: 'erster', 2: 'zweiter', 3: 'dritter', 4: 'vierter', 5: 'fünfter',\n        6: 'sechster', 7: 'siebter', 8: 'achter', 9: 'neunter', 10: 'zehnter',\n        11: 'elfter', 12: 'zwölfter', 13: 'dreizehnter', 14: 'vierzehnter', 15: 'fünfzehnter',\n        16: 'sechzehnter', 17: 'siebzehnter', 18: 'achtzehnter', 19: 'neunzehnter', 20: 'zwanzigster',\n        21: 'einundzwanzigster', 22: 'zweiundzwanzigster', 23: 'dreiundzwanzigster', 24: 'vierundzwanzigster',\n        25: 'fünfundzwanzigster', 26: 'sechsundzwanzigster', 27: 'siebenundzwanzigster', 28: 'achtundzwanzigster',\n        29: 'neunundzwanzigster', 30: 'dreißigster', 31: 'einunddreißigster'\n    };\n    return days[day] || day;\n}\n\nlet tempRaw = weather?.current_weather?.temperature ?? null;\nlet temp = tempRaw !== null ? Math.round(tempRaw) : null;\nlet weatherCode = weather?.current_weather?.weathercode ?? -1;\nlet event = calendar?.attributes?.message ?? 'keine Termine';\n\nlet time = now.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });\nlet weekday = now.toLocaleDateString('de-DE', { weekday: 'long' });\nlet month = now.toLocaleDateString('de-DE', { month: 'long' });\nlet year = now.getFullYear();\nlet spokenDay = dayToText(now.getDate());\nlet date = `${weekday}, der ${spokenDay} ${month} ${year}`;\n\nlet hour = now.getHours();\nlet greeting = 'Hallo';\n\nif (hour < 12) {\n    greeting = 'Guten Morgen';\n} else if (hour < 18) {\n    greeting = 'Guten Tag';\n} else {\n    greeting = 'Guten Abend';\n}\n\nlet weatherDescription = 'wechselhaftem Wetter';\n\nswitch (weatherCode) {\n    case 0:\n        weatherDescription = 'klarem Himmel';\n        break;\n    case 1:\n    case 2:\n    case 3:\n        weatherDescription = 'leicht bewölktem Himmel';\n        break;\n    case 45:\n    case 48:\n        weatherDescription = 'nebligem Wetter';\n        break;\n    case 51:\n    case 53:\n    case 55:\n        weatherDescription = 'leichtem Regen';\n        break;\n    case 61:\n    case 63:\n    case 65:\n        weatherDescription = 'regnerischem Wetter';\n        break;\n    case 71:\n    case 73:\n    case 75:\n        weatherDescription = 'Schneefall';\n        break;\n    case 80:\n    case 81:\n    case 82:\n        weatherDescription = 'Regenschauern';\n        break;\n    case 95:\n        weatherDescription = 'Gewitter';\n        break;\n}\n\nlet weatherText = 'Ich konnte das Wetter momentan nicht abrufen.';\nif (temp !== null) {\n    weatherText = `Draußen sind es aktuell ${temp} Grad bei ${weatherDescription}.`;\n}\n\nlet eventText = '';\nif (event === 'keine Termine') {\n    eventText = 'Du hast aktuell keine anstehenden Termine.';\n} else {\n    eventText = `Dein nächster Termin ist ${event}.`;\n}\n\nlet message =\n    `${greeting}. ` +\n    `Heute ist ${date}. ` +\n    `Die aktuelle Uhrzeit ist ${time}. ` +\n    `${weatherText} ` +\n    `${eventText}`;\n\nmsg.payload = {\n    message: message,\n    title: 'Jarvis Tagesinfo',\n    data: {\n        tts_text: message\n    }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 940,
        "y": 180,
        "wires": [
            [
                "daily_persistent_notification",
                "daily_response_mapper"
            ]
        ]
